C {code_shown.sym} 470 -447.5 0 0 {name=s1 only_toplevel=false value="
.control
let vlow = 0
let vhigh = 3.3

* --- Setup Inputs ---
* A = 0101010101010101 (21845)
alter vA15 = $&vlow
alter vA14 = $&vhigh
alter vA13 = $&vlow
alter vA12 = $&vhigh
alter vA11 = $&vlow
alter vA10 = $&vhigh
alter vA9  = $&vlow
alter vA8  = $&vhigh
alter vA7  = $&vlow
alter vA6  = $&vhigh
alter vA5  = $&vlow
alter vA4  = $&vhigh
alter vA3  = $&vlow
alter vA2  = $&vhigh
alter vA1  = $&vlow
alter vA0  = $&vhigh

* D = 00001111 (15)
alter vD7 = $&vlow
alter vD6 = $&vlow
alter vD5 = $&vlow
alter vD4 = $&vlow
alter vD3 = $&vlow
alter vD2 = $&vlow
alter vD1 = $&vhigh
alter vD0 = $&vhigh

* --- Control Signals ---
alter vJ  = $&vlow

* Setup vCLK as a pulse: Initial, Pulse, Delay, Rise, Fall, Width, Period
* Example: 10ns period, 50% duty cycle
alter @vCLK[pulse] = [ $&vlow $&vhigh 20n 1n 1n 10n 40n ]

* Setup vBr as a pulse: This triggers the branch offset. 
* We delay it so it's active during a specific clock edge.
alter @vBr[pulse] = [ $&vlow $&vhigh 15n 1n 1n 10n 40n ]
alter @vRSTn[pulse] = [ $&vhigh $&vlow 1n 1n 1n 1n 40n ]
* --- Run Simulation ---
tran 1n 40n
* --- Measurement at 30ns ---
* (Assuming the branch has processed and state is stable)
meas tran v1_0  find v(OUT0)  at=30n
meas tran v1_1  find v(OUT1)  at=30n
meas tran v1_2  find v(OUT2)  at=30n
meas tran v1_3  find v(OUT3)  at=30n
meas tran v1_4  find v(OUT4)  at=30n
meas tran v1_5  find v(OUT5)  at=30n
meas tran v1_6  find v(OUT6)  at=30n
meas tran v1_7  find v(OUT7)  at=30n
meas tran v1_8  find v(OUT8)  at=30n
meas tran v1_9  find v(OUT9)  at=30n
meas tran v1_10 find v(OUT10) at=30n
meas tran v1_11 find v(OUT11) at=30n
meas tran v1_12 find v(OUT12) at=30n
meas tran v1_13 find v(OUT13) at=30n
meas tran v1_14 find v(OUT14) at=30n
meas tran v1_15 find v(OUT15) at=30n

* --- Result Processing ---
let res1 = 0
if v1_0 > 1.6
  let res1 = res1 + 1
end
if v1_1 > 1.6
  let res1 = res1 + 2
end
if v1_2 > 1.6
  let res1 = res1 + 4
end
if v1_3 > 1.6
  let res1 = res1 + 8
end
if v1_4 > 1.6
  let res1 = res1 + 16
end
if v1_5 > 1.6
  let res1 = res1 + 32
end
if v1_6 > 1.6
  let res1 = res1 + 64
end
if v1_7 > 1.6
  let res1 = res1 + 128
end
if v1_8 > 1.6
  let res1 = res1 + 256
end
if v1_9 > 1.6
  let res1 = res1 + 512
end
if v1_10 > 1.6
  let res1 = res1 + 1024
end
if v1_11 > 1.6
  let res1 = res1 + 2048
end
if v1_12 > 1.6
  let res1 = res1 + 4096
end
if v1_13 > 1.6
  let res1 = res1 + 8192
end
if v1_14 > 1.6
  let res1 = res1 + 16384
end
if v1_15 > 1.6
  let res1 = res1 + 32768
end

echo "res_value:"
print res1

.endc
"}
C {schematics/main.sym} 90 20 0 0 {name=x1}
C {lab_wire.sym} 80 335 0 0 {name=p65 sig_type=std_logic lab=Br}
C {lab_wire.sym} 130 340 0 0 {name=p66 sig_type=std_logic lab=J}
C {lab_wire.sym} 190 335 0 0 {name=p67 sig_type=std_logic lab=RSTn}
C {lab_wire.sym} 90 -295 0 0 {name=p68 sig_type=std_logic lab=CLK}
