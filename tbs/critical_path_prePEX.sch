C {code_shown.sym} -220 -710 0 0 {name=s1 only_toplevel=false value="
.control
let vlow = 0
let vhigh = 3.3

* --- Setup Inputs ---
* A = 1111111111111111 (65535)
alter vA15 = $&vhigh
alter vA14 = $&vhigh
alter vA13 = $&vhigh
alter vA12 = $&vhigh
alter vA11 = $&vhigh
alter vA10 = $&vhigh
alter vA9  = $&vhigh
alter vA8  = $&vhigh
alter vA7  = $&vhigh
alter vA6  = $&vhigh
alter vA5  = $&vhigh
alter vA4  = $&vhigh
alter vA3  = $&vhigh
alter vA2  = $&vhigh
alter vA1  = $&vhigh
alter vA0  = $&vhigh

* D = 00001111 (15)
alter vD7 = $&vlow
alter vD6 = $&vlow
alter vD5 = $&vlow
alter vD4 = $&vlow
alter vD3 = $&vlow
alter vD2 = $&vlow
alter vD1 = $&vlow
alter vD0 = $&vlow

* --- Control Signals ---
alter @vJ[pulse] = [ $&vlow $&vhigh 1n 1n 1n 20n 40n ]

* Setup vCLK as a pulse: Initial, Pulse, Delay, Rise, Fall, Width, Period
* Example: 10ns period, 50% duty cycle
alter @vCLK[pulse] = [ $&vlow $&vhigh 10n 1n 1n 5n 20n ]

* Setup vBr as a pulse: This triggers the branch offset. 
* We delay it so it's active during a specific clock edge.
alter @vBr[pulse] = [ $&vhigh $&vlow 25n 1n 1n 20n 40n ]
alter @vRSTn[pulse] = [ $&vhigh $&vlow 1n 1n 1n 1n 40n ]
* --- Run Simulation ---
tran 1n 40n
* --- Measurement at 30ns ---
* (Assuming the branch has processed and state is stable)
meas tran v1_0  find v(OUT0)  at=30n
meas tran v1_1  find v(OUT1)  at=30n
meas tran v1_2  find v(OUT2)  at=30n
meas tran v1_3  find v(OUT3)  at=30n
meas tran v1_4  find v(OUT4)  at=30n
meas tran v1_5  find v(OUT5)  at=30n
meas tran v1_6  find v(OUT6)  at=30n
meas tran v1_7  find v(OUT7)  at=30n
meas tran v1_8  find v(OUT8)  at=30n
meas tran v1_9  find v(OUT9)  at=30n
meas tran v1_10 find v(OUT10) at=30n
meas tran v1_11 find v(OUT11) at=30n
meas tran v1_12 find v(OUT12) at=30n
meas tran v1_13 find v(OUT13) at=30n
meas tran v1_14 find v(OUT14) at=30n
meas tran v1_15 find v(OUT15) at=30n

* --- Result Processing ---
let res1 = 0
if v1_0 > 1.6
  let res1 = res1 + 1
end
if v1_1 > 1.6
  let res1 = res1 + 2
end
if v1_2 > 1.6
  let res1 = res1 + 4
end
if v1_3 > 1.6
  let res1 = res1 + 8
end
if v1_4 > 1.6
  let res1 = res1 + 16
end
if v1_5 > 1.6
  let res1 = res1 + 32
end
if v1_6 > 1.6
  let res1 = res1 + 64
end
if v1_7 > 1.6
  let res1 = res1 + 128
end
if v1_8 > 1.6
  let res1 = res1 + 256
end
if v1_9 > 1.6
  let res1 = res1 + 512
end
if v1_10 > 1.6
  let res1 = res1 + 1024
end
if v1_11 > 1.6
  let res1 = res1 + 2048
end
if v1_12 > 1.6
  let res1 = res1 + 4096
end
if v1_13 > 1.6
  let res1 = res1 + 8192
end
if v1_14 > 1.6
  let res1 = res1 + 16384
end
if v1_15 > 1.6
  let res1 = res1 + 32768
end

echo "res_value:"
print res1
meas tran read_fall TRIG v(Br) VAL=1.65 FALL=1 TARG v(OUT15) VAL=1.65 FALL=1 FROM=20n TO=30n
.endc
"}
C {schematics/main.sym} -600 -242.5 0 0 {name=x1}
